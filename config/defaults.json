{
  "project": { "name": "Default", "version": "1.0", "plugin": "object_counting" },
  "camera": {
    "source_type": "file",
    "source": "box-passing.mp4",
    "width": 640,
    "height": 480,
    "fps": 30,
    "loop": true,
    "rotation": 0,
    "flip": "none",
    "exposure": 0,
    "brightness": 0,
    "contrast": 0,
    "saturation": 0,
    "gain": 0
  },
  "preprocessing": {
    "blur": { "enabled": false, "kernel": 3 },
    "gaussian_blur": { "enabled": false, "kernel": 3, "sigma": 0 },
    "median_blur": { "enabled": false, "kernel": 3 },
    "clahe": { "enabled": false, "clip_limit": 2.0, "tile_grid": 8 },
    "hist_eq": { "enabled": false },
    "sharpen": { "enabled": false, "amount": 0 },
    "gamma": { "enabled": false, "value": 1.0 },
    "denoise": { "enabled": false, "strength": 10 },
    "morphology": { "enabled": false, "operation": "open", "kernel": 3, "iterations": 1 }
  },
  "color_calibration": {
    "profiles": [
      {
        "id": 1,
        "name": "Profile 1",
        "enabled": true,
        "color_space": "hsv",
        "lower_hsv": [0, 62, 100],
        "upper_hsv": [179, 255, 255],
        "overlay_color": "#00FF00"
      }
    ]
  },
  "roi": {
    "shapes": [
      { "id": 1, "name": "main", "type": "rect", "enabled": true, "x": 140, "y": 80, "w": 360, "h": 320 }
    ]
  },
  "counting": {
    "lines": [
      { "id": 1, "name": "line1", "x1": 320, "y1": 80, "x2": 320, "y2": 400, "enabled": true, "forward_label": "IN", "backward_label": "OUT" }
    ],
    "entry_zone": null,
    "exit_zone": null
  },
  "detection": {
    "backend": "hsv_contour",
    "confidence_threshold": 0.5,
    "nms_threshold": 0.4,
    "sensitivity": 50
  },
  "model": {
    "name": null,
    "path": null,
    "input_width": 300,
    "input_height": 300,
    "labels_file": "labels.txt"
  },
  "tracking": {
    "tracker_type": "centroid",
    "max_distance": 35,
    "object_timeout": 10,
    "iou_threshold": 0.3
  },
  "filters": {
    "min_area": 500,
    "max_area": 60000,
    "min_width": 10,
    "max_width": 640,
    "min_height": 10,
    "max_height": 480,
    "aspect_min": 0.2,
    "aspect_max": 5.0,
    "classes": ["object"]
  },
  "output": {
    "save_snapshots": false,
    "save_videos": false,
    "output_folder": "output",
    "csv_logging": false,
    "json_logging": false,
    "show_window": false
  },
  "logging": { "level": "info" },
  "performance": {
    "thread_count": 2,
    "gpu": false,
    "pi_optimization": false,
    "frame_skip": 0,
    "resize_factor": 1.0
  }
}
